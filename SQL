    resting_bpm NUMERIC(4,1),
    session_duration_hours NUMERIC(4,2),
    calories_burned NUMERIC(6,1),
    workout_type VARCHAR(20),
    fat_percentage NUMERIC(4,1),
    water_intake_liters NUMERIC(3,1),
    workout_frequency_days_per_week INT,
    experience_level INT,
    bmi NUMERIC(4,2)
);

