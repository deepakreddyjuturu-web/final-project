-- =========================================================================

-- Verification 1: Confirm total record insertion count
SELECT COUNT(*) AS total_records_inserted FROM gym_members_analysis;

-- Verification 2: Analyze average calories burned and heart rate per workout type
SELECT 
    workout_type,
    ROUND(AVG(calories_burned), 2) AS avg_calories,
    ROUND(AVG(avg_bpm), 1) AS avg_heart_rate,
    COUNT(*) AS total_sessions
FROM gym_members_analysis
GROUP BY workout_type
ORDER BY avg_calories DESC;