bronze_df = spark.read.csv(
    "/Volumes/workspace/gym_project/gym_data/gym_members_exercise_tracking_synthetic_data.csv",
    header=True,
    inferSchema=True
)
new_cols = []

for c in bronze_df.columns:
    c = c.replace(" ", "_")
    c = c.replace("(", "")
    c = c.replace(")", "")
    c = c.replace("/", "_")
    c = c.replace("-", "_")
    new_cols.append(c)

silver_df = bronze_df.toDF(*new_cols)

display(silver_df)

